# Nome exibido no dashboard
CLIENT_NAME=Nome do Cliente

# ── Meta Ads ────────────────────────────────────────────────────────────────
# Token de acesso longo (System User ou token renovado)
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx
# ID da conta de anúncios (com o prefixo act_)
META_ACCOUNT_ID=act_123456789

# ── Google Ads ───────────────────────────────────────────────────────────────
# Developer token (painel Google Ads > API Center)
GOOGLE_ADS_DEVELOPER_TOKEN=xxxxxxxxxxx
# OAuth2 — crie em console.cloud.google.com (tipo: Desktop)
GOOGLE_ADS_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=GOCSPX-xxxxxxxx
GOOGLE_ADS_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxx
# ID da conta (ex: 123-456-7890 ou 1234567890)
GOOGLE_ADS_CUSTOMER_ID=123-456-7890

# ── Google Analytics 4 ───────────────────────────────────────────────────────
# ID da propriedade GA4 (só os números, ex: 123456789)
GA4_PROPERTY_ID=123456789
# JSON inteiro da Service Account em uma linha
# Criar em: console.cloud.google.com > IAM > Service Accounts > chave JSON
GA4_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ── WooCommerce (dados de pedidos — substitui Metrilo) ───────────────────────
# URL da loja sem barra final
WC_STORE_URL=https://sualoja.com.br
# Chaves REST: WooCommerce > Configurações > Avançado > API REST
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
